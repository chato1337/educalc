# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
# Incluye el hostname con el que el navegador llama al API (ej. api.tudominio.com), no solo el del front.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,localhost:5173

# Database engine: sqlite or postgresql
DB_ENGINE=postgresql

# PostgreSQL settings (used when DB_ENGINE=postgresql)
POSTGRES_DB=educalc
POSTGRES_USER=didiercuetia
POSTGRES_PASSWORD=1814
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLite setting (used when DB_ENGINE=sqlite)
SQLITE_PATH=db.sqlite3

# JWT (SimpleJWT)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (origen del front en el navegador: esquema + host + puerto si no es 443/80)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTPS detrás de reverse proxy (nginx): recomendado en producción
# TRUST_X_FORWARDED_PROTO=true
# USE_X_FORWARDED_HOST=true
# Orígenes HTTPS para CSRF (admin, sesión); separados por coma, sin barra final
# CSRF_TRUSTED_ORIGINS=https://ineac.chatuzpark.store,https://api.chatuzpark.store