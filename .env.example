# =========================
# Docker Compose - eduCalc
# =========================
# Copia este archivo a ".env" en la raiz del proyecto:
# cp .env.example .env

# -------------------------
# Database service (db)
# -------------------------
DB_IMAGE=postgres:16-alpine
DB_CONTAINER_NAME=educalc_db
DB_PORT=5432
DB_HEALTHCHECK_INTERVAL=5s
DB_HEALTHCHECK_TIMEOUT=3s
DB_HEALTHCHECK_RETRIES=20

# Credenciales PostgreSQL (db y backend comparten estas variables)
POSTGRES_DB=educalc
POSTGRES_USER=educalc
POSTGRES_PASSWORD=educalc
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -------------------------
# Backend service (Django)
# -------------------------
BACKEND_CONTAINER_NAME=educalc_backend
BACKEND_PORT=8000

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DB_ENGINE=postgresql

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------
# Frontend service (Vite)
# -------------------------
FRONTEND_CONTAINER_NAME=educalc_frontend
FRONTEND_PORT=5173
CHOKIDAR_USEPOLLING=true
VITE_BACKEND_PROXY_TARGET=http://backend:8000
# Opcional. Hosts extra para Vite (coma-separados). ineac.chatuzpark.store va por defecto en vite.config.ts
# VITE_ALLOWED_HOSTS=
