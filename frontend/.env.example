# Nombre de la aplicación (barra lateral, login, título del documento, etc.).
VITE_APP_NAME=INEAC — Administración

# URL base del backend (desde el navegador). Sin barra final.
# En build de producción debe coincidir con el API público.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Opcional. Hosts extra permitidos por Vite en dev (reverse proxy / dominio público).
# Separados por coma. ineac.chatuzpark.store ya está incluido en vite.config.ts por defecto.
# VITE_ALLOWED_HOSTS=otro.ejemplo.com
